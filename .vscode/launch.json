    "version": "0.2.0",
    "configurations": [
        {
            "name": "gcoll-server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/gcoll-server",
            "cwd": "${workspaceFolder}",
            "debugAdapter": "dlv-dap",
            "env": {
                "TZ": "Asia/Shanghai"
            }
        }
    ],
    "compounds": [
        {
            "name": "服务端 + Web 前端",
            "configurations": [
                "gcoll-server"
            ],
            "preLaunchTask": "运行 Web 前端",
            "stopAll": true
        }
    ]
}
